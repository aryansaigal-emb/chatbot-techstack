# Get an OpenRouter API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Free OpenRouter router. You can also use a specific free model with :free.
OPENROUTER_MODEL=openrouter/free
OPENROUTER_APP_NAME=EMB RAG Chatbot
OPENROUTER_SITE_URL=http://localhost:5173

# Get from supabase.com → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# Comma-separated frontend origins allowed by CORS
FRONTEND_ORIGINS=http://localhost:5173,https://your-frontend.pages.dev
